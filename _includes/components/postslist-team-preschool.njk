 <div class="accordion">




<div class="accordion-item">
    <input id="accordion-trigger-pre" class="accordion-trigger-input" type="checkbox"></input>
      <label class="accordion-trigger" for="accordion-trigger-pre">Pre School (3 to 5 years of age)</label>
        <section class="accordion-animation-wrapper">
          <div class="accordion-animation">
            <div class="accordion-transform-wrapper">
         

{% if post.data.dapin %}



 <div class="accordion">




<div class="accordion-item">
    <input id="accordion-trigger-pre" class="accordion-trigger-input" type="checkbox"></input>
      <label class="accordion-trigger" for="accordion-trigger-pre">Dapin</label>
        <section class="accordion-animation-wrapper">
          <div class="accordion-animation">
            <div class="accordion-transform-wrapper">
         





	{% for post in postslist  %}
<div class="accordion-content">
<div class="gridteamwrapper">
<div class="gridteamimage">{% if post.data.image %}<div class="gridteamimg"><img src="https://ik.imagekit.io/webtactics/gloucester-pre-school/tr:w-200,h-200,q-60/static/img/pages/about/team/{{ post.data.image }}" loading="lazy" alt="{{ post.data.title }}" title="{{ post.data.title }}"/></div>{% else %}<div class="gridteamimg"><img src="https://ik.imagekit.io/webtactics/gloucester-pre-school/uploads/images/assets/person-icon-circle.png/tr:w-200,h-200,q-60" alt="{{ post.data.title }}" title="{{ post.data.title }}" ></div>{% endif %} </div>
<div class="gridteamtext"><p><strong>{{ post.data.title }}</strong></p>{% if post.content %}{{ post.content | safe }}{% endif %}</div>
</div>
</div>
{% endfor %}


                


          
            </div> 
          </div>
        </section>
</div>




</div>


{% elif post.data.gawul %}

