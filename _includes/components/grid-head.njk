<head>
<meta charset="utf-8">
<meta name="generator" content="{{ eleventy.generator }}">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="view-transition" content="same-origin">


<link rel="apple-touch-icon" sizes="180x180" href="{{metadata.url}}/static/favicon/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="{{metadata.url}}/static/favicon/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="{{metadata.url}}/static/favicon/favicon-16x16.png">
<link rel="manifest" href="{{metadata.url}}/static/favicon/site.webmanifest">

<meta name="apple-mobile-web-app-title" content="Gloucester Pre School" />

<link rel="canonical" href="{{metadata.url}}{{page.url}}">
<title>{{ title or metadata.title }} | {{ metadata.title }}</title>
<meta name="description" content="{{ description or metadata.description or eleventyComputed.description }}" />
<meta property="og:title" content="{{ title or metadata.title }}" />
<meta property="og:description" content="{{ description or metadata.description or eleventyComputed.description }}" />
<meta property="og:image" content="{{ image or metadata.image or eleventyComputed.image }}" />
<meta property="og:url" content="{{metadata.url}}{{page.url}}" />


{% set css %}
    {% include "assets/css/gps-grid.css" %}
      {% include "assets/css/slick.css" %}
  {% endset %}
  <style>{{ css | cssmin | safe }}</style>

</head>
